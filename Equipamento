public abstract class Equipamento {
    private String id;
    private String marca;
    private String tipo;
    private String funcao;
    private double potenciaNominal;
    private double geracaoAcumulada;

    public Equipamento(String id, String marca, String tipo, String funcao, double potenciaNominal) {
        this.id = id;
        this.marca = marca;
        this.tipo = tipo;
        this.funcao = funcao;
        this.potenciaNominal = potenciaNominal;
        this.geracaoAcumulada = 0.0;
    }

    // Getters para Encapsulamento
    public String getId() { return id; }
    public String getMarca() { return marca; }
    public String getTipo() { return tipo; }
    public String getFuncao() { return funcao; }
    public double getPotenciaNominal() { return potenciaNominal; }
    public double getGeracaoAcumulada() { return geracaoAcumulada; }

    // Método para registrar produção
    public void registrarProducao(double valor) {
        if (valor > 0) this.geracaoAcumulada += valor;
    }

    // Método universal de cálculo mencionado na sua Abstração
    public abstract double calcularRendimento();

    public abstract void exibirDetalhes();
}
